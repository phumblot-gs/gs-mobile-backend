{
  "name": "@gs-mobile-backend/lambda-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/local-server.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --format=cjs --external:@aws-sdk/* --external:aws-sdk --minify",
    "package": "cd dist && zip -r ../lambda-api.zip index.js",
    "deploy": "pnpm run build && pnpm run package",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@gs-mobile-backend/core": "workspace:*",
    "@aws-sdk/client-dynamodb": "^3.665.0",
    "@aws-sdk/client-s3": "^3.665.0",
    "@aws-sdk/client-secrets-manager": "^3.665.0",
    "@aws-sdk/lib-dynamodb": "^3.665.0",
    "@aws-sdk/s3-request-presigner": "^3.665.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.1",
    "hono": "^4.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.143",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.0",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  }
}
