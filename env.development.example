# Local development env vars
ENVIRONMENT=development
AWS_REGION=eu-west-1

# DynamoDB table names (override for local stub testing)
DYNAMO_OAUTH_STATE_TABLE=gs-mobile-oauth-state-development
DYNAMO_OAUTH_SESSIONS_TABLE=gs-mobile-oauth-sessions-development

# S3 buckets
S3_UPLOADS_BUCKET=gs-mobile-uploads-development
S3_PACKSHOTS_BUCKET=gs-mobile-packshots-development

# Public callback host (used to build OAuth redirect_uri)
PUBLIC_BASE_URL=http://localhost:3000

# Mobile app deep-link URL scheme
MOBILE_DEEP_LINK_SCHEME=gsmobile

# Secrets Manager secret IDs (or override with explicit values below for local)
SECRET_GS_OAUTH_CLIENT_ID=gs-mobile/development/gs-oauth-client-id
SECRET_GS_OAUTH_CLIENT_SECRET=gs-mobile/development/gs-oauth-client-secret
SECRET_GS_OAUTH_BASE_URL=gs-mobile/development/gs-oauth-base-url
SECRET_PHOTOROOM_API_KEY=gs-mobile/development/photoroom-api-key
SECRET_AUTORETOUCH_API_KEY=gs-mobile/development/autoretouch-api-key

# Optional: bypass Secrets Manager for local dev
# GS_OAUTH_CLIENT_ID=
# GS_OAUTH_CLIENT_SECRET=
# GS_OAUTH_BASE_URL=https://api-19.grand-shooting.com
# PHOTOROOM_API_KEY=
# AUTORETOUCH_API_KEY=
